# Copia este archivo a .env y ajusta valores
# Windows (PowerShell): Copy-Item .env.example .env

# Obligatorio para Django
SECRET_KEY=
DEBUG=True
USE_LOCAL_DB=True

# Agente Qwen (Ollama local compatible con OpenAI)
LLM_PROVIDER=qwen_local
QWEN_MODEL=qwen3:8b
QWEN_BASE_URL=http://127.0.0.1:11434/v1
QWEN_API_KEY=
QWEN_TIMEOUT_SECONDS=30
QWEN_TEMPERATURE=0
QWEN_MAX_TOKENS=512

# Checkpoints conversacionales durables en un archivo SQLite separado.
AGENT_CHECKPOINT_BACKEND=sqlite
AGENT_CHECKPOINT_SQLITE_PATH=agent_checkpoints.sqlite3
LANGGRAPH_STRICT_MSGPACK=true

# Observabilidad opcional; el agente no envía mensajes ni payloads a LangSmith.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=torresegura-agent
AGENT_ENVIRONMENT=development

# Correo (en dev se recomienda consola)
# Si no defines EMAIL_BACKEND, en DEBUG se usará console backend.
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Si usas SMTP (producción o pruebas reales)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Sistema <no-reply@dominio.com>

# Opcional (si decides manejar Google OAuth por settings)
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=
PUERTA_WEBHOOK_TOKEN=
